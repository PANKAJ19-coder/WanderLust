<% layout('./layouts/boilerplate.ejs')%>
<div id="filters" class="mt-3 mb-3">
        <div class="filter">
            <a href="/listing/Summer_Trips"><i class="fa-solid fa-sun"></i>
            <p>Summer Trips</p></a>
        </div>
        <div class="filter">
            <a href="/listing/Iconic_Cities"><i class="fa-solid fa-landmark"></i>
            <p>Iconic Cities</p></a>
        </div>
        <div class="filter">
            <a href="/listing/Beach"><i class="fa-solid fa-umbrella-beach"></i>
            <p>Beach</p></a>
        </div>
        <div class="filter">
            <a href="/listing/Mountains"><i class="fa-solid fa-mountain"></i>
            <p>Mountains</p></a>
        </div>
        <div class="filter">
            <a href="/listing/Nature"><i class="fa-brands fa-pagelines"></i>
            <p>Nature</p></a>
        </div>
        <div class="filter">
            <a href="/listing/Resort"><i class="fa-solid fa-hotel"></i>
            <p>Resort</p></a>
        </div>
        <div class="filter">
            <a href="/listing/downtown"><i class="fa-solid fa-city"></i>
            <p>Downtown</p></a>
        </div>
        <div class="filter cow">
            <a href="/listing/Farmhouse"><i class="fa-solid fa-cow"></i>
            <p>Farmhouse</p></a>
        </div>
    </div>  
<body>
    <h4 class="searchHeading">Availabe Listings from <%= region%></h4>
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 listings mt-3">
        <% for(let result of result1){%>
    <a href="/listing/<%=result._id%>" class="anchor">
         <div class="card col listing-card">
          <img src="<%=result.image.url%>" class="card-img-top img -fluid" alt="listing/image">
          <div class="card-body">
            <p class="card-text"><b><%=result.title%></b><br>
            &#8377; <%=result.price.toLocaleString("en-IN") %> /night<i class="tax-info">&nbsp;&nbsp; &nbsp;+18%GST</i>
            </p>
          </div>
        </div>
    </a>
     <% }%>
     <% for(let result of result2){%>
    <a href="/listing/<%=result._id%>" class="anchor">
         <div class="card col listing-card ">
          <img src="<%=result.image.url%>" class="card-img-top img -fluid" alt="listing/image">
          <div class="card-body">
            <p class="card-text"><b><%=result.title%></b><br>
            &#8377; <%=result.price.toLocaleString("en-IN") %> /night<i class="tax-info">&nbsp;&nbsp; &nbsp;+18%GST</i>
            </p>
          </div>
        </div>
    </a>
     <% }%>
     </div>
     
     </body>